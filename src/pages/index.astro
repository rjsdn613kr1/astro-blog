---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

// 카테고리별 최신 글 3개씩 묶기
const categoryMap = new Map<string, typeof sortedPosts>();
for (const post of sortedPosts) {
  if (post.data.category && !post.data.draft) {
    const arr = categoryMap.get(post.data.category) ?? [];
    if (arr.length < 3) arr.push(post);
    categoryMap.set(post.data.category, arr);
  }
}
const categoryEntries = [...categoryMap.entries()];
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">

    <!-- 저자 소개 섹션 -->
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        G.D
      </h1>
      <p class="my-2 leading-relaxed">
        생각과 경험을 기록하는 공간입니다.
      </p>
      <div class="mt-4 flex max-sm:flex-col sm:items-center">
        <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Social Links:</div>
        <Socials />
      </div>
    </section>

    <!-- Featured 섹션 -->
    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={["pt-12 pb-6", "border-b border-border"]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <!-- 카테고리별 섹션 -->
    {
      categoryEntries.length > 0
        ? categoryEntries.map(([category, catPosts]) => (
            <section class="pt-12 pb-6 border-b border-border">
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-2xl font-semibold tracking-wide">{category}</h2>
                <LinkButton
                  href={`${base}/categories/${category}/`}
                  class="text-sm hover:text-accent"
                >
                  전체 보기
                  <IconArrowRight class="inline-block rtl:-rotate-180" />
                </LinkButton>
              </div>
              <ul>
                {catPosts.map(data => (
                  <Card variant="h3" {...data} />
                ))}
              </ul>
            </section>
          ))
        : recentPosts.length > 0 && (
            <section id="recent-posts" class="pt-12 pb-6">
              <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
              <ul>
                {recentPosts
                  .slice(0, SITE.postPerIndex)
                  .map(data => (
                    <Card variant="h3" {...data} />
                  ))}
              </ul>
            </section>
          )
    }

    <div class="my-8 text-center">
      <LinkButton href={`${base}/posts/`}>
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", import.meta.env.BASE_URL);
    }
  });
</script>
